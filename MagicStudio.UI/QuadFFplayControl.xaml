<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MagicStudio.UI.QuadFFplayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="SlotPlayPauseStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Width"      Value="36" />
            <Setter Property="Height"     Value="32" />
            <Setter Property="Padding"    Value="0" />
        </Style>
        <Style x:Key="SlotOpenStyle" TargetType="Button">
            <Setter Property="Height"  Value="32" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style x:Key="SlotSpeedBoxStyle" TargetType="NumberBox">
            <Setter Property="Minimum"                Value="0.1" />
            <Setter Property="Maximum"                Value="100.0" />
            <Setter Property="SmallChange"            Value="0.1" />
            <Setter Property="LargeChange"            Value="0.5" />
            <Setter Property="SpinButtonPlacementMode" Value="Hidden" />
            <Setter Property="Width"                  Value="80" />
        </Style>
    </UserControl.Resources>

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <canvas:CanvasControl
            x:Name="QuadCanvas"
            Grid.Row="0"
            Draw="QuadCanvas_Draw"
            CreateResources="QuadCanvas_CreateResources" />

        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="6,4"
            Text="QuadFFplay — 1 CanvasControl, 4 players, shared D3D11 device"
            FontSize="11"
            Foreground="White"
            Opacity="0.7" />

        <!-- Slot 1 -->
        <Grid Grid.Row="1" Padding="8,4"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"   />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Slot 1" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button    Grid.Column="1" Tag="0" Content="Open"
                       Style="{StaticResource SlotOpenStyle}"
                       Click="OpenSlot_Click" />
            <Button    Grid.Column="2" Tag="0" Content="&#xE768;"
                       Margin="6,0,0,0"
                       Style="{StaticResource SlotPlayPauseStyle}"
                       x:Name="PlayPauseButton0"
                       Click="PlayPause_Click" />
            <Slider    Grid.Column="3" Tag="0"
                       x:Name="ProgressSlider0"
                       Margin="8,0"
                       Minimum="0" Maximum="1" Value="0"
                       VerticalAlignment="Center"
                       PointerPressed="ProgressSlider_PointerPressed"
                       PointerCaptureLost="ProgressSlider_PointerCaptureLost"
                       ValueChanged="ProgressSlider_ValueChanged" />
            <TextBlock Grid.Column="4" x:Name="TimeText0"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Speed" VerticalAlignment="Center" FontSize="12" />
                <NumberBox Tag="0" x:Name="SpeedBox0" Value="1.0"
                           Style="{StaticResource SlotSpeedBoxStyle}" />
                <Button Tag="0" Content="Set" Padding="10,4" Click="SetSpeed_Click" />
            </StackPanel>
        </Grid>

        <!-- Slot 2 -->
        <Grid Grid.Row="2" Padding="8,4"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"   />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Slot 2" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button    Grid.Column="1" Tag="1" Content="Open"
                       Style="{StaticResource SlotOpenStyle}"
                       Click="OpenSlot_Click" />
            <Button    Grid.Column="2" Tag="1" Content="&#xE768;"
                       Margin="6,0,0,0"
                       Style="{StaticResource SlotPlayPauseStyle}"
                       x:Name="PlayPauseButton1"
                       Click="PlayPause_Click" />
            <Slider    Grid.Column="3" Tag="1"
                       x:Name="ProgressSlider1"
                       Margin="8,0"
                       Minimum="0" Maximum="1" Value="0"
                       VerticalAlignment="Center"
                       PointerPressed="ProgressSlider_PointerPressed"
                       PointerCaptureLost="ProgressSlider_PointerCaptureLost"
                       ValueChanged="ProgressSlider_ValueChanged" />
            <TextBlock Grid.Column="4" x:Name="TimeText1"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Speed" VerticalAlignment="Center" FontSize="12" />
                <NumberBox Tag="1" x:Name="SpeedBox1" Value="1.0"
                           Style="{StaticResource SlotSpeedBoxStyle}" />
                <Button Tag="1" Content="Set" Padding="10,4" Click="SetSpeed_Click" />
            </StackPanel>
        </Grid>

        <!-- Slot 3 -->
        <Grid Grid.Row="3" Padding="8,4"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"   />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Slot 3" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button    Grid.Column="1" Tag="2" Content="Open"
                       Style="{StaticResource SlotOpenStyle}"
                       Click="OpenSlot_Click" />
            <Button    Grid.Column="2" Tag="2" Content="&#xE768;"
                       Margin="6,0,0,0"
                       Style="{StaticResource SlotPlayPauseStyle}"
                       x:Name="PlayPauseButton2"
                       Click="PlayPause_Click" />
            <Slider    Grid.Column="3" Tag="2"
                       x:Name="ProgressSlider2"
                       Margin="8,0"
                       Minimum="0" Maximum="1" Value="0"
                       VerticalAlignment="Center"
                       PointerPressed="ProgressSlider_PointerPressed"
                       PointerCaptureLost="ProgressSlider_PointerCaptureLost"
                       ValueChanged="ProgressSlider_ValueChanged" />
            <TextBlock Grid.Column="4" x:Name="TimeText2"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Speed" VerticalAlignment="Center" FontSize="12" />
                <NumberBox Tag="2" x:Name="SpeedBox2" Value="1.0"
                           Style="{StaticResource SlotSpeedBoxStyle}" />
                <Button Tag="2" Content="Set" Padding="10,4" Click="SetSpeed_Click" />
            </StackPanel>
        </Grid>

        <!-- Slot 4 -->
        <Grid Grid.Row="4" Padding="8,4"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"   />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Slot 4" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button    Grid.Column="1" Tag="3" Content="Open"
                       Style="{StaticResource SlotOpenStyle}"
                       Click="OpenSlot_Click" />
            <Button    Grid.Column="2" Tag="3" Content="&#xE768;"
                       Margin="6,0,0,0"
                       Style="{StaticResource SlotPlayPauseStyle}"
                       x:Name="PlayPauseButton3"
                       Click="PlayPause_Click" />
            <Slider    Grid.Column="3" Tag="3"
                       x:Name="ProgressSlider3"
                       Margin="8,0"
                       Minimum="0" Maximum="1" Value="0"
                       VerticalAlignment="Center"
                       PointerPressed="ProgressSlider_PointerPressed"
                       PointerCaptureLost="ProgressSlider_PointerCaptureLost"
                       ValueChanged="ProgressSlider_ValueChanged" />
            <TextBlock Grid.Column="4" x:Name="TimeText3"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Speed" VerticalAlignment="Center" FontSize="12" />
                <NumberBox Tag="3" x:Name="SpeedBox3" Value="1.0"
                           Style="{StaticResource SlotSpeedBoxStyle}" />
                <Button Tag="3" Content="Set" Padding="10,4" Click="SetSpeed_Click" />
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="5"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Button 
                Content="Reset All" 
                HorizontalAlignment="Left" 
                Margin="0,6,6,0"
                Padding="10,4" 
                Click="ResetAll_Click" />
        </Grid>
    </Grid>
</UserControl>
