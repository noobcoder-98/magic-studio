<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MagicStudio.UI.MagicFFplayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Video surface for MagicFFplay (ffplay.c C++ port) -->
        <canvas:CanvasControl
            x:Name="FFplayCanvas"
            Grid.Row="0"
            Draw="FFplayCanvas_Draw"
            CreateResources="FFplayCanvas_CreateResources" />

        <!-- Label overlay so it is clear which renderer produced this frame -->
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="6,4"
            Text="MagicFFplay (ffplay.c port)"
            FontSize="11"
            Foreground="White"
            Opacity="0.7" />

        <!-- Controls bar -->
        <Grid Grid.Row="1" Padding="8,4" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="FfPlayPauseButton"
                    Grid.Column="0"
                    Content="&#xE768;"
                    FontFamily="Segoe MDL2 Assets"
                    Width="40" Height="40"
                    Click="FfPlayPauseButton_Click" />

            <Slider x:Name="FfProgressSlider"
                    Grid.Column="1"
                    Margin="8,0"
                    Minimum="0" Maximum="1" Value="0"
                    VerticalAlignment="Center"
                    PointerPressed="FfProgressSlider_PointerPressed"
                    PointerCaptureLost="FfProgressSlider_PointerCaptureLost"
                    ValueChanged="FfProgressSlider_ValueChanged" />

            <TextBlock x:Name="FfTimeText"
                       Grid.Column="2"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>
    </Grid>
</UserControl>
