<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MagicStudio.UI.MagicFFplayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Video surface for MagicFFplay (ffplay.c C++ port) -->
        <canvas:CanvasControl
            x:Name="FFplayCanvas"
            Grid.Row="0"
            Draw="FFplayCanvas_Draw"
            CreateResources="FFplayCanvas_CreateResources" />

        <!-- Label overlay so it is clear which renderer produced this frame -->
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="6,4"
            Text="MagicFFplay (ffplay.c port)"
            FontSize="11"
            Foreground="White"
            Opacity="0.7" />

        <!-- Controls bar -->
        <Grid Grid.Row="1" Padding="8,4" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Row 0: play/pause, progress, time -->
            <Button x:Name="FfPlayPauseButton"
                    Grid.Row="0" Grid.Column="0"
                    Content="&#xE768;"
                    FontFamily="Segoe MDL2 Assets"
                    Width="40" Height="40"
                    Click="FfPlayPauseButton_Click" />

            <Slider x:Name="FfProgressSlider"
                    Grid.Row="0" Grid.Column="1"
                    Margin="8,0"
                    Minimum="0" Maximum="1" Value="0"
                    VerticalAlignment="Center"
                    PointerPressed="FfProgressSlider_PointerPressed"
                    PointerCaptureLost="FfProgressSlider_PointerCaptureLost"
                    ValueChanged="FfProgressSlider_ValueChanged" />

            <TextBlock x:Name="FfTimeText"
                       Grid.Row="0" Grid.Column="2"
                       Text="0:00 / 0:00"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <!-- Row 1: speed number box + pitch toggle -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Speed"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,2"
                        Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center">
                <NumberBox x:Name="FfSpeedNumberBox"
                           Minimum="0.1" Maximum="100.0"
                           Value="100.0"
                           SmallChange="0.1"
                           LargeChange="0.5"
                           SpinButtonPlacementMode="Hidden"
                           Width="110" />
                <Button x:Name="FfSetSpeedButton"
                        Content="Set"
                        Padding="12,4"
                        Click="FfSetSpeedButton_Click" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <ToggleButton x:Name="FfPitchButton"
                              Content="Pitch"
                              IsChecked="True"
                              FontSize="12"
                              Padding="8,4"
                              Click="FfPitchButton_Click" />
                <TextBlock x:Name="FfPitchForcedText"
                           Text="(forced)"
                           FontSize="11"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
