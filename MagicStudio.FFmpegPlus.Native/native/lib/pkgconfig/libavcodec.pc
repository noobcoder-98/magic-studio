prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libavcodec
Description: FFmpeg codec library
Version: 62.28.100
Requires: 
Requires.private: libswresample >= 6.3.100, libavutil >= 60.26.100
Conflicts:
Libs: "-L${libdir}" -lavcodec
Libs.private: -lmfuuid -lole32 -lstrmiids -lole32 -luser32
Cflags: "-I${includedir}"

